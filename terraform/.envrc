# ./terraform/.envrc

log_status "Loading Terraform environment..."

# Set sensitive variables via TF_VAR_* — do NOT commit actual secrets.
# Example:
#   export TF_VAR_proxmox_api_token="terraform@pve!token-name=uuid-secret"
#   export TF_VAR_tailscale_oauth_client_id="tskey-client-..."
#   export TF_VAR_tailscale_oauth_client_secret="..."
#   export TF_VAR_cloudflare_api_token="..."
#   export TF_VAR_cloudflare_zone_id="..."   # Zone ID from Cloudflare dashboard

log_status "Terraform environment loaded."
