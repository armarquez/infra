# ./terraform/.envrc

log_status "Loading Terraform environment..."

# Secrets are NOT exported here. They are pulled from Ansible Vault at
# command time by the justfile via terraform/scripts/tf-secrets.sh. See:
#   - terraform/justfile (`_with-secrets` recipe)
#   - terraform/scripts/tf-secrets.sh (bridge — vault → TF_VAR_*)
#
# Non-secret Terraform config (endpoints, node names, etc.) lives in
# terraform/environments/<env>/variables.tf with sensible defaults.

log_status "Terraform environment loaded."
