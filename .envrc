# ./.envrc
# Project Root .envrc

export PROJECT_ROOT=$(pwd)

# Activate mise-managed toolchain pinned in ./mise.toml (just, opentofu, yq).
# Uses `mise env` directly (rather than `use mise`) so no per-user direnvrc
# setup is required. Subsystem .envrc files pull this in via `source_up`.
if command -v mise >/dev/null; then
  eval "$(mise env -s bash)"
fi

log_status "Project root .envrc loaded. Tool-specific environments will be loaded via 'direnv exec' by just."
