# Remote Incus server configuration
remote_name := 'incus-remote'
remote_ip := '192.168.1.88'
remote_port := '8443'
remote_url := 'https://' + remote_ip + ':' + remote_port

# Snapshot configuration
initial_snapshot_name := 'clean'

# List recipes by default
default:
  just --list

# Configure remote Incus server connection
setup-remote:
  #!/usr/bin/env sh
  echo "🔧 Configuring Incus remote: {{remote_name}}"
  echo "   URL: {{remote_url}}"
  if incus remote list --format csv | grep -q "^{{remote_name}},"; then
    echo "⚠️  Remote '{{remote_name}}' already exists. Removing it first..."
    incus remote remove {{remote_name}}
  fi
  echo "➕ Adding remote..."
  incus remote add {{remote_name}} {{remote_url}}
  echo "✅ Remote '{{remote_name}}' configured successfully"

# Set remote Incus server as default
set-remote-default:
  #!/usr/bin/env sh
  echo "🔄 Setting {{remote_name}} as default Incus remote"
  incus remote switch {{remote_name}}
  echo "✅ Default remote set to: {{remote_name}}"

# Set local Incus as default
set-local-default:
  #!/usr/bin/env sh
  echo "🔄 Setting 'local' as default Incus remote"
  incus remote switch local
  echo "✅ Default remote set to: local"

# Show current remote configuration
show-remote-config:
  #!/usr/bin/env sh
  echo "📋 Current Incus Remote Configuration:"
  echo ""
  incus remote list
  echo ""
  echo "Default remote: $(incus remote get-default)"

# Ensure Incus instance is running
check-incus-instance HOST:
  #!/usr/bin/env sh
  if ! incus list --format csv | grep -i -q "^{{HOST}},running"; then
    echo "⚠️  Instance '{{HOST}}' is not running. Starting it now..."
    incus start {{HOST}}
    sleep 5  # Give some time for it to start
  fi
  echo "✅  Instance '{{HOST}}' is running."

# Attach to instance
attach HOST:
  incus console {{HOST}} --type=vga

# Create a snapshot
snapshot HOST NAME:
  incus snapshot create {{HOST}} {{NAME}}

# Create initial snapshot
snapshot-initial HOST:
  just snapshot {{HOST}} {{initial_snapshot_name}}

# Restore instance to snapshot
restore HOST NAME=initial_snapshot_name:
  #!/usr/bin/env sh
  echo "🔄 Restoring {{HOST}} to snapshot {{NAME}}"
  just check-incus-instance {{HOST}}
  incus stop {{HOST}}
  incus snapshot restore {{HOST}} {{NAME}}
  incus start {{HOST}}
  echo "✅ {{HOST}} restored to {{NAME}} and restarted"

# List all snapshots for instance
list-snapshots HOST:
  #!/usr/bin/env sh
  echo "📸 Snapshots for {{HOST}}:"
  incus info {{HOST}} | grep -A 10 "Snapshots:"

# Create a timestamped snapshot for current state
snapshot-timestamp HOST:
  #!/usr/bin/env sh
  TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
  echo "📸 Creating timestamped snapshot: {{HOST}}_$TIMESTAMP"
  incus snapshot create {{HOST}} "snapshot_$TIMESTAMP"
  echo "✅ Snapshot created: snapshot_$TIMESTAMP"
