default:
  just --list

# Generate answer file from Ansible vault, then prepare bootable Proxmox ISO
prepare-iso:
  @./scripts/generate-answer-file.sh
  @./scripts/prepare-iso.sh

# Generate Proxmox answer file only (pulls password from Ansible vault via 1Password)
generate-answer-file:
  @./scripts/generate-answer-file.sh

# Show ISO build status
status:
  #!/usr/bin/env sh
  echo "=== Proxmox ISO Status ==="
  if [ -f downloads/proxmox-ve_9.1-1-auto.iso ]; then
    echo "✅ Prepared ISO ready: downloads/proxmox-ve_9.1-1-auto.iso"
    ls -lh downloads/proxmox-ve_9.1-1-auto.iso
  elif [ -f downloads/proxmox-ve_9.1-1.iso ]; then
    echo "⚠️  Base ISO present but answer file not embedded — run 'just prepare-iso'"
    ls -lh downloads/proxmox-ve_9.1-1.iso
  else
    echo "❌ No ISO found — run 'just prepare-iso'"
  fi
  echo ""
  echo "=== Answer File ==="
  if [ -f http/auto.toml ]; then
    echo "✅ http/auto.toml exists (generated)"
  else
    echo "❌ http/auto.toml missing — run 'just generate-answer-file'"
  fi
