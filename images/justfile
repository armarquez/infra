
# Default command
default:
  just --list

# Build the Proxmox image
build *ARGS:
  @just _ensure-deps
  @./scripts/validate.sh
  @echo "Running Packer build..."
  @./scripts/build-with-kvm.sh {{ARGS}}

# Initializes and validates the Packer configuration
validate:
  @just _ensure-deps
  @./scripts/validate.sh

# Convert built image to Incus format and import
import-to-incus:
  @./scripts/convert-to-incus.sh

# Build and import to Incus in one step
build-and-import *ARGS:
  @just _ensure-deps
  @./scripts/validate.sh
  @echo "Running Packer build..."
  @./scripts/build-with-kvm.sh {{ARGS}}
  @echo "Converting to Incus format..."
  @./scripts/convert-to-incus.sh

# Clean up build artifacts
clean:
  @echo "Cleaning up build artifacts..."
  rm -rf output/
  rm -rf packer_cache/
  @echo "✅ Cleanup complete"

# Internal recipe to ensure dependencies are met
_ensure-deps:
  @./scripts/check-deps.sh --quiet || (echo "🔧 Dependencies missing. Installing automatically..." && ./scripts/install-deps.sh)

# Check dependencies status
check-deps:
  @./scripts/check-deps.sh

# Force install/update all dependencies
install-deps:
  @./scripts/install-deps.sh

# Check KVM availability and provide setup instructions
check-kvm:
  @./scripts/check-kvm.sh

# Prepare Proxmox ISO with embedded answer file
prepare-iso:
  @./scripts/prepare-iso.sh

# Build with debug logging (PACKER_LOG=1)
build-debug *ARGS:
  @just _ensure-deps
  @./scripts/validate.sh
  @echo "🐛 Running Packer build with debug logging..."
  @PACKER_LOG=1 ./scripts/build-with-kvm.sh {{ARGS}}

# Build with trace logging (most verbose)
build-trace *ARGS:
  @just _ensure-deps
  @./scripts/validate.sh
  @echo "🔍 Running Packer build with trace logging..."
  @PACKER_LOG=TRACE ./scripts/build-with-kvm.sh {{ARGS}}

# Build with custom log level (DEBUG, INFO, WARN, ERROR, TRACE)
build-log LEVEL *ARGS:
  @just _ensure-deps
  @./scripts/validate.sh
  @echo "📝 Running Packer build with {{LEVEL}} logging..."
  @PACKER_LOG={{LEVEL}} ./scripts/build-with-kvm.sh {{ARGS}}

# Build and import with debug logging
build-and-import-debug *ARGS:
  @just _ensure-deps
  @./scripts/validate.sh
  @echo "🐛 Running Packer build with debug logging..."
  @PACKER_LOG=1 ./scripts/build-with-kvm.sh {{ARGS}}
  @echo "Converting to Incus format..."
  @./scripts/convert-to-incus.sh

# Build with verbose Ansible output for troubleshooting
build-ansible-debug *ARGS:
  @just _ensure-deps
  @./scripts/validate.sh
  @echo "🐛 Running Packer build with verbose Ansible output..."
  @ANSIBLE_STDOUT_CALLBACK=debug PACKER_LOG=1 ./scripts/build-with-kvm.sh {{ARGS}}

# === ITERATIVE DEVELOPMENT RECIPES ===

# Build base Proxmox image (slow, run once)
build-base *ARGS:
  @just _ensure-deps
  @echo "🏗️  Building base Proxmox image (this takes ~10 minutes)..."
  @./scripts/build-base.sh {{ARGS}}

# Fast provisioning iteration using existing base image
provision-only *ARGS:
  @just _ensure-deps
  @echo "⚡ Fast provisioning iteration using base image..."
  @./scripts/build-provision.sh {{ARGS}}

# Debug provisioning with verbose output
provision-debug *ARGS:
  @just _ensure-deps
  @echo "🐛 Debug provisioning with verbose output..."
  @ANSIBLE_STDOUT_CALLBACK=debug PACKER_LOG=1 ./scripts/build-provision.sh {{ARGS}}

# Clean up base image artifacts
clean-base:
  @echo "🗑️  Cleaning base image artifacts..."
  rm -rf output-base/
  @echo "✅ Base artifacts cleaned"

# Full workflow: build base, then provision
build-full *ARGS:
  @echo "🚀 Running full build workflow..."
  @just build-base {{ARGS}}
  @just provision-only {{ARGS}}

# Show build status
status:
  @echo "=== Dependency Status ==="
  @./scripts/check-deps.sh || echo "❌ Some dependencies missing - run 'just install-deps'"
  @echo ""
  @echo "=== Base Image Status ==="
  @if [ -d "output-base" ]; then echo "✅ Base image directory exists"; ls -la output-base/; else echo "❌ No base image found - run 'just build-base'"; fi
  @echo ""
  @echo "=== Final Image Status ==="
  @if [ -d "output" ]; then echo "✅ Final image directory exists"; ls -la output/; else echo "❌ No final image found"; fi
  @echo ""
  @echo "=== Incus Images ==="
  @incus image list | grep -E "(ALIAS|proxmox)" || echo "No ProxMox images found in Incus"
