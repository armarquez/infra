{# Managed by mqz-cerebro role — edit templates/Caddyfile.j2, not the deployed copy. #}

{
    email {{ cerebro_caddy_email }}
    acme_dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    # Alt ports because DSM's nginx owns 80/443. Set in the global block so
    # site blocks below auto-bind to these (Caddy uses https_port for HTTPS
    # sites when no explicit port is given in the site address).
    http_port 8880
    https_port 4443

    # Access logs — JSON output so future log aggregation (Loki, etc.) can
    # ingest cleanly. Tail on cerebro at /volume1/docker/caddy/logs/access.log
    # (bind-mounted from /var/log/caddy inside the container). `log default`
    # sets the logger for every site block below; no per-site override needed.
    log default {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 10
            roll_keep_for 720h
        }
        format json
    }
}

# Reject requests whose source IP is outside the LAN or Tailscale networks.
# Imported by every site block so protection is enforced uniformly.
(private_only) {
    @denied not remote_ip {{ cerebro_caddy_allowed_cidrs | join(' ') }}
    respond @denied "Access restricted to LAN and Tailscale networks." 403
}

# code-server (in-browser VS Code). Runs on cerebro with a published host
# port 8443, so Caddy on host network reaches it via localhost.
code.mqz.casa {
    import private_only
    reverse_proxy http://localhost:8443
}

# Syncthing GUI. Already runs with network_mode: host on cerebro, so
# localhost:8384 works the same as with any host-bound service.
syncthing.mqz.casa {
    import private_only
    reverse_proxy http://localhost:8384
}
