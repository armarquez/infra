# Environment Variables
bt := '0'
export RUST_BACKTRACE := bt
log := "warn"
export JUST_LOG := log

# --- Ansible Galaxy ---
_ansible_galaxy_req_file := "requirements.yaml"

# List recipes by default
default:
  just --list

# Check if 1Password CLI is installed and authenticated
check-op:
  #!/usr/bin/env sh
  # Check for both 'op' and 'op.exe' (for WSL)
  OP_CMD=""
  if command -v op.exe > /dev/null; then
    OP_CMD="op.exe"
  elif command -v op > /dev/null; then
    OP_CMD="op"
  else
    echo "❌ 1Password CLI ('op' or 'op.exe') is not installed. Please install it first."
    exit 1
  fi
  # Check for desktop integration or authenticated session
  ACCOUNT_OUTPUT="$($OP_CMD account list 2>/dev/null)"
  if [ -z "$ACCOUNT_OUTPUT" ]; then
    echo "❌ 1Password CLI is installed but no accounts found. Please run: $OP_CMD signin"
    exit 1
  fi
  echo "✅ 1Password CLI is installed and authenticated:"
  echo "$ACCOUNT_OUTPUT"

# Ensure Incus instance is running
check-incus-instance HOST:
  #!/usr/bin/env sh
  if ! incus list --format csv | grep -i -q "^{{HOST}},running"; then
    echo "⚠️  Instance '{{HOST}}' is not running. Starting it now..."
    incus start {{HOST}}
    sleep 5
  fi
  echo "✅  Instance '{{HOST}}' is running."

##########
## Python environment (uv)
##########

# Create .venv and install all dev dependencies (production + testing + linting)
install:
  #!/usr/bin/env sh
  if ! command -v uv >/dev/null; then
    echo "❌ uv not found — install with: curl -LsSf https://astral.sh/uv/install.sh | sh"
    exit 1
  fi
  echo "🐍 Creating/updating virtual environment with uv..."
  uv venv .venv --python 3.12
  echo "📦 Syncing production dependencies..."
  uv pip install -r requirements.in
  echo "📦 Syncing development dependencies..."
  uv pip install -r requirements-dev.in
  echo "🎉 All Python dependencies installed."

# Lock/compile dependencies (regenerates requirements.txt and requirements-dev.txt)
compile:
  uv pip compile requirements.in -o requirements.txt
  uv pip compile requirements-dev.in -o requirements-dev.txt

# Remove the virtual environment
clean-venv:
  rm -rf .venv
  @echo "🗑️ .venv removed."

##########
## Ansible operations
##########

# Install Ansible Galaxy roles + collections
reqs *FORCE:
  ansible-galaxy role install -r requirements.yaml -p galaxy_roles {{FORCE}}
  ansible-galaxy collection install -r requirements.yaml {{FORCE}}

# Initial Proxmox setup (SSH password auth, run once)
setup HOST *TAGS: check-op
  ansible-playbook -i ./inventories/home-network/inventory-setup.yaml run.yaml --limit {{HOST}} {{TAGS}} --ask-pass -e SETUP=true

# Run main playbook against a production host
run HOST *TAGS: check-op
  ansible-playbook -b run.yaml --limit {{HOST}} {{TAGS}}

# Shared entry point for ad-hoc troubleshooting. Swap the invoked script as focus shifts.
troubleshoot:
  bash {{justfile_directory()}}/scripts/troubleshoot-cerebro.sh

# Perform an action (encrypt/decrypt/edit) on Ansible vault
vault ACTION: check-op
  EDITOR='code --wait' ansible-vault {{ACTION}} group_vars/secrets.yaml

# View decrypted vault contents (read-only)
vault-view: check-op
  ansible-vault view group_vars/secrets.yaml

# Test vault password retrieval from 1Password
vault-test: check-op
  #!/usr/bin/env sh
  echo "🔐 Testing vault password retrieval from 1Password..."
  if ~/bin/op-vault > /dev/null; then
    echo "✅ Successfully retrieved vault password from 1Password"
  else
    echo "❌ Failed to retrieve vault password from 1Password"
    exit 1
  fi

# Install op-vault script to ~/bin/
install-op-vault:
  #!/usr/bin/env sh
  echo "📦 Installing op-vault script to ~/bin/..."
  mkdir -p ~/bin
  cp bin/op-vault ~/bin/op-vault
  chmod +x ~/bin/op-vault
  echo "✅ op-vault script installed to ~/bin/op-vault"

##########
## Linting & testing
##########

# Run ansible-lint on all roles
lint:
  ansible-lint roles/

# Run full molecule test suite for a role (create → converge → verify → destroy)
molecule-test ROLE="mqz-proxmox":
  cd roles/{{ROLE}} && \
    ANSIBLE_ALLOW_BROKEN_CONDITIONALS=true \
    ANSIBLE_ROLES_PATH="{{justfile_directory()}}/galaxy_roles:{{justfile_directory()}}/roles" \
    molecule test

# Converge only — applies role without destroying container (fast iteration)
molecule-converge ROLE="mqz-proxmox":
  cd roles/{{ROLE}} && \
    ANSIBLE_ALLOW_BROKEN_CONDITIONALS=true \
    ANSIBLE_ROLES_PATH="{{justfile_directory()}}/galaxy_roles:{{justfile_directory()}}/roles" \
    molecule converge

# Re-run verify against existing container
molecule-verify ROLE="mqz-proxmox":
  cd roles/{{ROLE}} && \
    ANSIBLE_ALLOW_BROKEN_CONDITIONALS=true \
    ANSIBLE_ROLES_PATH="{{justfile_directory()}}/galaxy_roles:{{justfile_directory()}}/roles" \
    molecule verify

# Destroy molecule test container
molecule-destroy ROLE="mqz-proxmox":
  cd roles/{{ROLE}} && \
    ANSIBLE_ALLOW_BROKEN_CONDITIONALS=true \
    ANSIBLE_ROLES_PATH="{{justfile_directory()}}/galaxy_roles:{{justfile_directory()}}/roles" \
    molecule destroy

##########
## Repo utilities
##########

# Update all git submodules to latest remote
sub-update:
  git submodule update --remote --recursive

# Add a Galaxy role as a git submodule
sub-add URL *NAME:
    #!/usr/bin/env sh
    if [ -z "{{NAME}}" ]; then
        basename=$(basename "{{URL}}" .git)
        git submodule add {{URL}} "roles/${basename}"
        git submodule update --init --recursive
        git add .gitmodules "roles/${basename}"
        git commit -m "Adds ${basename} as a submodule"
    else
        git submodule add {{URL}} "roles/{{NAME}}"
        git submodule update --init --recursive
        git add .gitmodules "roles/{{NAME}}"
        git commit -m "Adds {{NAME}} as a submodule"
    fi
